---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const galleries = await getCollection('galleries');
  return galleries.map((g) => ({
    params: { slug: g.id },
    props: { gallery: g },
  }));
}

const { gallery } = Astro.props;
const { Content } = await render(gallery);
const { title, date, intro, photos } = gallery.data;
const heroPhoto = photos?.[0];
const restPhotos = photos?.slice(1);
---

<Layout title={title}>
  <article>
    <header>
      <h1>{title}</h1>
      <time>{date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
    </header>

    {heroPhoto && (
      <figure class="hero">
        <img src={heroPhoto.src} alt={heroPhoto.alt ?? ''} data-index="0" class="lightbox-trigger" />
        {heroPhoto.caption && <figcaption>{heroPhoto.caption}</figcaption>}
      </figure>
    )}

    {intro && <p class="intro">{intro}</p>}

    {restPhotos && restPhotos.length > 0 && (
      <div class="photos">
        {restPhotos.map((photo, i) => (
          <figure>
            <img src={photo.src} alt={photo.alt ?? ''} loading="lazy" data-index={i + 1} class="lightbox-trigger" />
            {photo.caption && <figcaption>{photo.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}

    <div class="prose">
      <Content />
    </div>
  </article>

  <a href="/galleries" class="back">← back to work</a>
</Layout>

<!-- Lightbox -->
<div id="lightbox-data" data-photos={JSON.stringify((photos ?? []).map(p => ({ src: p.src, alt: p.alt ?? '', caption: p.caption ?? '' })))} hidden></div>
<div id="lightbox" aria-hidden="true">
  <div id="lightbox-backdrop"></div>
  <button id="lightbox-close" aria-label="Close">×</button>
  <button id="lightbox-prev" aria-label="Previous">&#8592;</button>
  <button id="lightbox-next" aria-label="Next">&#8594;</button>
  <div id="lightbox-content">
    <img id="lightbox-img" src="" alt="" />
    <p id="lightbox-caption"></p>
  </div>
</div>

<script>
  const photos = JSON.parse(document.getElementById('lightbox-data')!.dataset.photos ?? '[]');

  const lightbox = document.getElementById('lightbox');
  const backdrop = document.getElementById('lightbox-backdrop');
  const img = document.getElementById('lightbox-img') as HTMLImageElement;
  const caption = document.getElementById('lightbox-caption');
  const prevBtn = document.getElementById('lightbox-prev');
  const nextBtn = document.getElementById('lightbox-next');

  let current = 0;

  function open(index: number) {
    current = index;
    show();
    lightbox!.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightbox!.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function show() {
    const p = photos[current];
    img!.src = p.src;
    img!.alt = p.alt;
    caption!.textContent = p.caption;
    caption!.style.display = p.caption ? 'block' : 'none';
    prevBtn!.style.visibility = current > 0 ? 'visible' : 'hidden';
    nextBtn!.style.visibility = current < photos.length - 1 ? 'visible' : 'hidden';
  }

  document.querySelectorAll('.lightbox-trigger').forEach(el => {
    (el as HTMLElement).style.cursor = 'zoom-in';
    el.addEventListener('click', () => {
      open(parseInt((el as HTMLElement).dataset.index ?? '0'));
    });
  });

  backdrop!.addEventListener('click', close);
  document.getElementById('lightbox-close')!.addEventListener('click', close);
  prevBtn!.addEventListener('click', () => { if (current > 0) { current--; show(); } });
  nextBtn!.addEventListener('click', () => { if (current < photos.length - 1) { current++; show(); } });

  document.addEventListener('keydown', (e) => {
    if (lightbox!.getAttribute('aria-hidden') === 'true') return;
    if (e.key === 'ArrowLeft' && current > 0) { current--; show(); }
    if (e.key === 'ArrowRight' && current < photos.length - 1) { current++; show(); }
    if (e.key === 'Escape') close();
  });
</script>

<style>
  article header {
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: 2.2rem;
    margin-bottom: 0.4rem;
  }

  time {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--muted);
  }

  .hero {
    margin-bottom: 2rem;
    text-align: center;
    overflow: hidden;
  }

  .hero img {
    width: 100%;
    max-width: 780px;
    height: auto;
    margin: 0 auto;
    transition: transform 0.4s ease;
  }

  .hero img:hover {
    transform: scale(1.02);
  }

  .hero figcaption {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--muted);
    margin-top: 0.5rem;
  }

  .intro {
    max-width: 620px;
    margin: 0 auto 3rem;
    text-align: center;
    font-size: 1.05rem;
    line-height: 1.7;
    font-style: italic;
    color: var(--muted);
  }

  .photos {
    columns: 2;
    column-gap: 1rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 600px) {
    .photos {
      columns: 1;
    }
  }

  .photos figure {
    break-inside: avoid;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .photos img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.4s ease;
  }

  .photos img:hover {
    transform: scale(1.04);
  }

  figcaption {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--muted);
  }

  .prose {
    max-width: 680px;
    margin: 0 auto;
    font-size: 1rem;
    line-height: 1.75;
  }

  .prose :global(p) {
    margin-bottom: 1.2em;
  }

  .prose :global(h2) {
    font-size: 1.3rem;
    margin: 2em 0 0.5em;
  }

  .back {
    display: inline-block;
    margin-top: 3rem;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--muted);
    text-decoration: none;
  }

  .back:hover {
    color: var(--text);
  }

  /* Lightbox */
  #lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #lightbox[aria-hidden='true'] {
    pointer-events: none;
    visibility: hidden;
  }

  #lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.82);
  }

  #lightbox-content {
    position: relative;
    z-index: 1;
    max-width: min(90vw, 1100px);
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  #lightbox-img {
    max-width: 100%;
    max-height: 82vh;
    object-fit: contain;
    display: block;
  }

  #lightbox-caption {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  #lightbox-close {
    position: fixed;
    top: 1.25rem;
    right: 1.5rem;
    z-index: 2;
    background: none;
    border: none;
    color: white;
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0.7;
    padding: 0.25rem 0.5rem;
  }

  #lightbox-close:hover {
    opacity: 1;
  }

  #lightbox-prev,
  #lightbox-next {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    background: none;
    border: none;
    color: white;
    font-size: 2rem;
    cursor: pointer;
    opacity: 0.6;
    padding: 1rem;
    line-height: 1;
  }

  #lightbox-prev { left: 1rem; }
  #lightbox-next { right: 1rem; }

  #lightbox-prev:hover,
  #lightbox-next:hover {
    opacity: 1;
  }
</style>
