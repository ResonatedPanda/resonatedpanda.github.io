---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const galleries = (await getCollection('galleries')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Work">
  <h1>Work</h1>

  {galleries.length === 0 ? (
    <p class="empty">Nothing here yet.</p>
  ) : (
    <ul class="gallery-list">
      {galleries.map((g) => (
        <li>
          <a href={`/galleries/${g.id}`}>
            {g.data.cover && (
              <div class="thumb">
                <img src={g.data.cover} alt={g.data.title} />
              </div>
            )}
            <div class="meta">
              <span class="title">{g.data.title}</span>
              {g.data.description && <span class="desc">{g.data.description}</span>}
              <span class="date">{g.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long' })}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  )}
</Layout>

<style>
  h1 {
    font-size: 2.5rem;
    margin-bottom: 3rem;
  }

  .empty {
    color: var(--muted);
    font-style: italic;
  }

  .gallery-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2.5rem;
  }

  .gallery-list a {
    text-decoration: none;
    display: block;
  }

  .thumb {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #e5e3de;
    margin-bottom: 0.75rem;
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .gallery-list a:hover .thumb img {
    transform: scale(1.02);
  }

  .meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .title {
    font-size: 1rem;
  }

  .desc {
    font-size: 0.9rem;
    color: var(--muted);
    font-style: italic;
  }

  .date {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--muted);
  }
</style>
